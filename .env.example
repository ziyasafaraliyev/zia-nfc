# ══════════════════════════════════════════════
# Zia NFC — environment (never commit .env.local)
# ══════════════════════════════════════════════

# Required — HMAC session signing (openssl rand -hex 32)
SESSION_SECRET=

# Supabase (service role is server-only — never expose to client)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Super-admin login (use a long random password in production)
ADMIN_EMAIL=
ADMIN_PASSWORD=

# Canonical site URL (used for origin checks in production)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Chat API (optional in dev; required for production chat)
NVIDIA_API_KEY=

# Visit notify → Telegram (optional)
# BotFather-dan bot token; chat id default 1309527475
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=1309527475
